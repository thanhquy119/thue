GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-3.5-flash-lite
OCR_GEMINI_MODEL=gemini-3.5-flash-lite
ENABLE_OCR_FALLBACK=true
ENABLE_OCR_LAB=false
RATE_LIMIT_SALT=replace-with-a-random-secret

# Durable legal-document ingestion
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
LEGAL_BLOB_ACCESS=private
LEGAL_MAX_SOURCE_BYTES=100000000
LEGAL_BLOB_SOFT_LIMIT_BYTES=750000000
LEGAL_RUN_RETENTION_DAYS=30
LEGAL_CRON_MAX_RUNS=8
CRON_SECRET=replace-with-a-long-random-secret
INGESTION_ADMIN_SECRET=replace-with-a-different-long-random-secret
