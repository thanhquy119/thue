GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-3.5-flash-lite
OCR_GEMINI_MODEL=gemini-3.5-flash-lite
ENABLE_OCR_FALLBACK=true
ENABLE_OCR_LAB=false

# Optional fallback: only discovers official URLs; never answers directly from Search Grounding.
# Keep disabled by default. New free projects may receive provider 404 for both Gemini 2.5
# Grounding models even when the AI Studio quota dashboard displays the model family.
ENABLE_SEARCH_GROUNDING_FALLBACK=false
SEARCH_GROUNDING_GEMINI_MODEL=gemini-2.5-flash-lite
SEARCH_GROUNDING_MAX_RESULTS=6

RATE_LIMIT_SALT=replace-with-a-random-secret

# Durable legal-document ingestion
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
LEGAL_BLOB_ACCESS=private
LEGAL_MAX_SOURCE_BYTES=100000000
LEGAL_BLOB_SOFT_LIMIT_BYTES=750000000
LEGAL_RUN_RETENTION_DAYS=30
# Start one document per daily Cron run by default; code hard-caps this at two on the free-tier policy.
LEGAL_CRON_MAX_RUNS=1
CRON_SECRET=replace-with-a-long-random-secret
INGESTION_ADMIN_SECRET=replace-with-a-different-long-random-secret

# Web Push. VAPID keys are generated once and kept in Private Blob; no private key is committed.
WEB_PUSH_SUBJECT=https://thue-ro.vercel.app
WEB_PUSH_MAX_SUBSCRIPTIONS=1000
WEB_PUSH_MAX_DOCUMENT_AGE_DAYS=60
WEB_PUSH_RECEIPT_RETENTION_DAYS=30
WEB_PUSH_CRON_MAX_REVISIONS=2
WEB_PUSH_MAX_DELIVERIES_PER_RUN=40
