    "pdf-parse": "^2.4.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "word-extractor": "^1.0.4",
    "workflow": "4.6.0"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/word-extractor": "^1.0.6",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tsx": "4.22.5",
    "typescript": "5.9.3"
  },
  "type": "module"
